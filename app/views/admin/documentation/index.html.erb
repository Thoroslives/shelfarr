<div class="mx-auto max-w-6xl">
  <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <h1 class="font-bold text-4xl text-white">Configuration Documentation</h1>
      <p class="mt-2 text-gray-400 max-w-3xl">
        Reference for Shelfarr configuration fields, defaults, and expected values.
        Use this page together with <%= link_to "Settings", admin_settings_path, class: "text-blue-400 hover:text-blue-300 underline" %>
        and <%= link_to "Download Clients", admin_download_clients_path, class: "text-blue-400 hover:text-blue-300 underline" %>.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Settings", admin_settings_path, class: "rounded-md px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white text-sm" %>
      <%= link_to "Download Clients", admin_download_clients_path, class: "rounded-md px-4 py-2 bg-blue-700 hover:bg-blue-600 text-white text-sm" %>
    </div>
  </div>

  <div class="mb-6 rounded-lg border border-blue-800 bg-blue-950/40 p-4">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-blue-300">Path Template Variables</h2>
    <p class="mt-2 text-sm text-blue-100">
      Available placeholders for path templates:
      <%= @path_template_variables.map { |var| "{#{var}}" }.join(", ") %>
    </p>
  </div>

  <section class="mb-8 bg-gray-900 rounded-lg border border-gray-800">
    <div class="px-6 py-4 border-b border-gray-800">
      <h2 class="font-bold text-xl text-white">Download Client Fields</h2>
      <p class="mt-1 text-sm text-gray-500">Configured in Admin → Download Clients.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800 bg-gray-900/70">
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Field</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Required</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-300">Description</th>
          </tr>
        </thead>
        <tbody>
          <% @download_client_fields.each do |field| %>
            <tr class="border-b border-gray-800/70 last:border-0">
              <td class="px-4 py-3 align-top text-gray-100"><code><%= field[:key] %></code></td>
              <td class="px-4 py-3 align-top">
                <% if field[:required] %>
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold bg-green-900/40 text-green-300 border border-green-800">Yes</span>
                <% else %>
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold bg-gray-800 text-gray-300 border border-gray-700">Optional</span>
                <% end %>
              </td>
              <td class="px-4 py-3 align-top text-gray-400"><%= field[:description] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <% ordered_categories = SettingsService::CATEGORIES.keys + (@settings_reference.keys - SettingsService::CATEGORIES.keys).sort %>
  <% ordered_categories.each do |category| %>
    <% settings = @settings_reference[category] %>
    <% next if settings.blank? %>

    <section class="mb-6 bg-gray-900 rounded-lg border border-gray-800">
      <div class="px-6 py-4 border-b border-gray-800">
        <h2 class="font-bold text-xl text-white"><%= SettingsService::CATEGORIES[category] || category.titleize %></h2>
        <p class="mt-1 text-sm text-gray-500"><%= settings.size %> fields</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800 bg-gray-900/70">
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Setting Key</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Type</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Default</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-300">Description</th>
            </tr>
          </thead>
          <tbody>
            <% settings.each do |setting| %>
              <tr class="border-b border-gray-800/70 last:border-0">
                <td class="px-4 py-3 align-top text-gray-100"><code><%= setting[:key] %></code></td>
                <td class="px-4 py-3 align-top text-gray-300"><%= setting[:type] %></td>
                <td class="px-4 py-3 align-top text-gray-300"><code><%= setting[:default] %></code></td>
                <td class="px-4 py-3 align-top text-gray-400"><%= setting[:description] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
